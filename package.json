{
  "name": "platform-tech-test",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "concurrently -n be,fe -c blue,magenta \"npm:start-backend\" \"npm:start-frontend\"",
    "start-backend": "tsx watch backend/src/index.ts",
    "start-frontend": "vite frontend",
    "typecheck": "tsc -p backend && tsc -p frontend",
    "lint": "eslint \"backend/**/*.ts\" \"frontend/**/*.{ts,tsx}\"",
    "lint:fix": "eslint --fix \"backend/**/*.ts\" \"frontend/**/*.{ts,tsx}\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:backend": "vitest run --project backend",
    "test:frontend": "vitest run --project frontend"
  },
  "dependencies": {
    "classnames": "^2.5.1",
    "dotenv": "17.4.2",
    "express": "5.2.1",
    "multer": "^2.1.1",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "react-dropzone": "^15.0.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/express": "^5.0.6",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.7.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/supertest": "^7.2.0",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "@vitejs/plugin-react": "6.0.1",
    "concurrently": "^9.2.1",
    "eslint": "^8.57.1",
    "eslint-config-airbnb": "^19.0.4",
    "eslint-config-airbnb-typescript": "^18.0.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^4.6.2",
    "jsdom": "^29.1.1",
    "supertest": "^7.2.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vite": "8.0.10",
    "vitest": "^4.1.6"
  }
}
